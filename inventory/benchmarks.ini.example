[benchmark_vms]
bench-hp1 ansible_host=10.0.0.x ansible_user=ubuntu proxmox_node=hp1 proxmox_storage=nvme-local
bench-hp2 ansible_host=10.0.0.y ansible_user=ubuntu proxmox_node=hp2 proxmox_storage=nvme-local
bench-hp3 ansible_host=10.0.0.z ansible_user=ubuntu proxmox_node=hp3 proxmox_storage=nvme-local
bench-hp3-sas ansible_host=10.0.0.s ansible_user=ubuntu proxmox_node=hp3 proxmox_storage=sas-hp3
bench-dell1 ansible_host=10.0.0.w ansible_user=ubuntu proxmox_node=dell1 proxmox_storage=nvme-dell

[iperf_servers]
bench-hp1

# Optional WAN/VPN baseline. The Frankfurt VPS now runs a persistent iperf3
# server on TCP/5201, so you can keep the [iperf_servers] group above and
# override the target without SSH-managing the VPS:
#
# ansible-playbook -i inventory/benchmarks.ini playbooks/benchmarks.yml \
#   -e benchmark_iperf_host=72.61.95.150 \
#   -e benchmark_iperf_manage_server=false
