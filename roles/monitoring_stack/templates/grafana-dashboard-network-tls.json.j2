{
  "uid": "homelab-network-tls",
  "title": "Network And TLS Health",
  "tags": ["homelab", "network", "tls", "influxdb"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Ping latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"ping\" and r._field == \"average_response_ms\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "options": {}
    },
    {
      "id": 2,
      "title": "Packet loss",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"ping\" and r._field == \"percent_packet_loss\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "options": {}
    },
    {
      "id": 3,
      "title": "Ping result code",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"ping\" and r._field == \"result_code\") |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "Certificate days remaining",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "d", "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 14 }, { "color": "green", "value": 30 } ] } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"x509_cert\" and r._field == \"expiry\") |> map(fn: (r) => ({ r with _value: float(v: r._value) / 86400.0 })) |> aggregateWindow(every: v.windowPeriod, fn: min, createEmpty: false)"
        }
      ],
      "options": {}
    },
    {
      "id": 5,
      "title": "Certificate verification code",
      "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"x509_cert\" and r._field == \"verification_code\") |> last()"
        }
      ]
    }
  ]
}
