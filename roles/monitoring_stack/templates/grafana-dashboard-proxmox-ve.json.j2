{
  "uid": "proxmox-ve-homelab",
  "title": "Proxmox VE Homelab",
  "tags": ["homelab", "proxmox", "influxdb", "telegraf"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"node_fqdn\", predicate: (r) => r._measurement == \"proxmox\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      },
      {
        "name": "resource",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"vm_name\", predicate: (r) => r._measurement == \"proxmox\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU load",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"cpuload\") |> filter(fn: (r) => exists r.node_fqdn and (\"${node}\" == \"All\" or r.node_fqdn == \"${node}\")) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.node_fqdn }))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Node memory used",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"mem_used_percentage\") |> filter(fn: (r) => exists r.node_fqdn and (\"${node}\" == \"All\" or r.node_fqdn == \"${node}\")) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.node_fqdn }))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node uptime",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "d", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"uptime\") |> filter(fn: (r) => exists r.node_fqdn and (\"${node}\" == \"All\" or r.node_fqdn == \"${node}\")) |> last() |> map(fn: (r) => ({ r with _value: float(v: r._value) / 86400.0, _field: r.node_fqdn }))"
        }
      ]
    },
    {
      "id": 4,
      "title": "VM and container CPU load",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"cpuload\") |> filter(fn: (r) => exists r.vm_name and (\"${resource}\" == \"All\" or r.vm_name == \"${resource}\")) |> filter(fn: (r) => not exists r.node_fqdn or \"${node}\" == \"All\" or r.node_fqdn == \"${node}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: if exists r.vm_name then r.vm_name else r.node_fqdn }))"
        }
      ]
    },
    {
      "id": 5,
      "title": "VM and container memory used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"mem_used_percentage\") |> filter(fn: (r) => exists r.vm_name and (\"${resource}\" == \"All\" or r.vm_name == \"${resource}\")) |> filter(fn: (r) => not exists r.node_fqdn or \"${node}\" == \"All\" or r.node_fqdn == \"${node}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.vm_name }))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Disk used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and r._field == \"disk_used_percentage\") |> filter(fn: (r) => not exists r.node_fqdn or \"${node}\" == \"All\" or r.node_fqdn == \"${node}\") |> filter(fn: (r) => not exists r.vm_name or \"${resource}\" == \"All\" or r.vm_name == \"${resource}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: if exists r.vm_name then r.vm_name else r.node_fqdn }))"
        }
      ]
    },
    {
      "id": 7,
      "title": "Network throughput",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and (r._field == \"netin\" or r._field == \"netout\")) |> filter(fn: (r) => not exists r.node_fqdn or \"${node}\" == \"All\" or r.node_fqdn == \"${node}\") |> filter(fn: (r) => not exists r.vm_name or \"${resource}\" == \"All\" or r.vm_name == \"${resource}\") |> derivative(unit: 1s, nonNegative: true) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: (if exists r.vm_name then r.vm_name else r.node_fqdn) + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 8,
      "title": "Resource status",
      "type": "table",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"proxmox\" and (r._field == \"status\" or r._field == \"cpuload\" or r._field == \"mem_used_percentage\" or r._field == \"disk_used_percentage\" or r._field == \"uptime\")) |> filter(fn: (r) => not exists r.node_fqdn or \"${node}\" == \"All\" or r.node_fqdn == \"${node}\") |> filter(fn: (r) => not exists r.vm_name or \"${resource}\" == \"All\" or r.vm_name == \"${resource}\") |> last() |> keep(columns: [\"_time\", \"node_fqdn\", \"vm_name\", \"type\", \"_field\", \"_value\"])"
        }
      ]
    }
  ]
}
