input {
  beats {
    port => 5044
  }

  udp {
    port => 5514
    type => "syslog"
  }

  tcp {
    port => 5514
    type => "syslog"
  }
}

filter {
  if [type] == "syslog" {
    grok {
      match => {
        "message" => "%{SYSLOGTIMESTAMP:syslog_timestamp} %{SYSLOGHOST:syslog_hostname} %{DATA:syslog_program}(?:\\[%{POSINT:syslog_pid}\\])?: %{GREEDYDATA:syslog_message}"
      }
    }
    syslog_pri { }
    date {
      match => [ "syslog_timestamp", "MMM  d HH:mm:ss", "MMM dd HH:mm:ss" ]
    }
  }
}

output {
  if [type] == "syslog" {
    opensearch {
      hosts => ["http://opensearch:9200"]
      index => "homelab-syslog-%{+YYYY.MM.dd}"
    }
  } else if [@metadata][beat] {
    opensearch {
      hosts => ["http://opensearch:9200"]
      index => "homelab-%{[@metadata][beat]}-%{+YYYY.MM.dd}"
    }
  } else {
    opensearch {
      hosts => ["http://opensearch:9200"]
      index => "homelab-generic-%{+YYYY.MM.dd}"
    }
  }
}
