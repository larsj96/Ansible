{
  "uid": "homelab-ilo-health",
  "title": "iLO Health",
  "tags": ["homelab", "ilo", "snmp", "influxdb"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "device",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"device\", predicate: (r) => r._measurement == \"snmp_device\" or r._measurement == \"hp_ilo_temperature\")",
        "refresh": 1,
        "includeAll": true,
        "allValue": "All",
        "current": { "selected": true, "text": "All", "value": "All" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Power meter current",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "watt", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"snmp_device\" and r._field == \"power_meter_current_watts\") |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last()" }]
    },
    {
      "id": 2,
      "title": "Max temperature",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "celsius", "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 65 }, { "color": "red", "value": 80 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["max"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_temperature\" and r._field == \"celsius\") |> filter(fn: (r) => r._value > -90) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last()" }]
    },
    {
      "id": 3,
      "title": "Power supply load",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "used = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_power_supply\" and r._field == \"used_watts\")\ncapacity = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_power_supply\" and r._field == \"capacity_watts\")\njoin(tables: {used: used, capacity: capacity}, on: [\"_time\", \"device\", \"power_supply_index\"]) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> map(fn: (r) => ({ r with _value: float(v: r._value_used) / float(v: r._value_capacity) * 100.0 })) |> last()" }]
    },
    {
      "id": 4,
      "title": "SNMP freshness",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 120 }, { "color": "red", "value": 300 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"snmp_device\" and r._field == \"sys_uptime\") |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last() |> map(fn: (r) => ({ r with _value: float(v: uint(v: now()) - uint(v: r._time)) / 1000000000.0, _field: r.device }))" }]
    },
    {
      "id": 5,
      "title": "Temperature sensors",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "celsius", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_temperature\" and r._field == \"celsius\") |> filter(fn: (r) => r._value > -90) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.device + \" sensor \" + r.sensor_index + \" \" + r.location }))" }]
    },
    {
      "id": 6,
      "title": "Temperature sensor table",
      "type": "table",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_temperature\" and (r._field == \"celsius\" or r._field == \"threshold_celsius\" or r._field == \"condition\")) |> filter(fn: (r) => r._value > -90) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last() |> keep(columns: [\"_time\", \"device\", \"sensor_index\", \"location\", \"_field\", \"_value\"])" }]
    },
    {
      "id": 7,
      "title": "Power supply watts",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "watt", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => (r._measurement == \"snmp_device\" and (r._field == \"power_meter_current_watts\" or r._field == \"power_meter_previous_watts\")) or (r._measurement == \"hp_ilo_power_supply\" and (r._field == \"used_watts\" or r._field == \"capacity_watts\"))) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)" }]
    },
    {
      "id": 8,
      "title": "Power supply inventory",
      "type": "table",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_power_supply\" and (r._field == \"used_watts\" or r._field == \"capacity_watts\" or r._field == \"condition\" or r._field == \"status\")) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last() |> keep(columns: [\"_time\", \"device\", \"power_supply_index\", \"model\", \"serial\", \"spare_part\", \"_field\", \"_value\"])" }]
    },
    {
      "id": 9,
      "title": "Fan condition",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_fan\" and (r._field == \"condition\" or r._field == \"present\")) |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last() |> keep(columns: [\"_time\", \"device\", \"fan_index\", \"locale\", \"_field\", \"_value\"])" }]
    },
    {
      "id": 10,
      "title": "Storage battery",
      "type": "table",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hp_ilo_storage_battery\") |> filter(fn: (r) => \"${device}\" == \"All\" or r.device == \"${device}\") |> last() |> keep(columns: [\"_time\", \"device\", \"battery_index\", \"model\", \"_field\", \"_value\"])" }]
    }
  ]
}
