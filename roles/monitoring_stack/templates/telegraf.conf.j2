[agent]
  interval = "30s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  collection_jitter = "0s"
  flush_interval = "30s"
  flush_jitter = "5s"
  precision = ""
  hostname = "{{ inventory_hostname }}"
  omit_hostname = false

[[outputs.influxdb_v2]]
  urls = ["http://influxdb:8086"]
  token = "$INFLUX_TOKEN"
  organization = "{{ telegraf_influxdb_org }}"
  bucket = "{{ telegraf_influxdb_bucket }}"

[[inputs.docker]]
  endpoint = "unix:///var/run/docker.sock"
  gather_services = false

[[inputs.ping]]
  urls = {{ telegraf_ping_targets | to_json }}
  count = 3
  method = "native"

[[inputs.x509_cert]]
  sources = {{ telegraf_x509_targets | to_json }}
  timeout = "5s"
  insecure_skip_verify = true

{% if monitoring_proxmox_enabled | bool %}
{% for target in monitoring_proxmox_targets %}
[[inputs.proxmox]]
  base_url = "{{ target.base_url }}"
  api_token = "$PROXMOX_API_TOKEN"
  node_name = "{{ target.name }}"
  insecure_skip_verify = true
  response_timeout = "10s"
{% endfor %}
{% endif %}

{% if monitoring_snmp_enabled | bool %}
{% for target in monitoring_snmp_targets %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "snmp_device"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"

  [[inputs.snmp.field]]
    name = "sys_name"
    oid = "1.3.6.1.2.1.1.5.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "sys_uptime"
    oid = "1.3.6.1.2.1.1.3.0"
{% endfor %}
{% endif %}


{% if monitoring_fortigate_snmp_enabled | bool %}
{% for target in monitoring_fortigate_snmp_targets %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ target.community | default(monitoring_snmp_community) }}"
  timeout = "5s"
  retries = 2
  name = "fortigate_system"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"

  [[inputs.snmp.field]]
    name = "sys_name"
    oid = "1.3.6.1.2.1.1.5.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "sys_uptime"
    oid = "1.3.6.1.2.1.1.3.0"

  [[inputs.snmp.field]]
    name = "serial"
    oid = "1.3.6.1.4.1.12356.100.1.1.1.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "firmware_version"
    oid = "1.3.6.1.4.1.12356.101.4.1.1.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "cpu_percent"
    oid = "1.3.6.1.4.1.12356.101.4.1.3.0"

  [[inputs.snmp.field]]
    name = "memory_percent"
    oid = "1.3.6.1.4.1.12356.101.4.1.4.0"

  [[inputs.snmp.field]]
    name = "memory_capacity_kb"
    oid = "1.3.6.1.4.1.12356.101.4.1.5.0"

  [[inputs.snmp.field]]
    name = "disk_usage_mb"
    oid = "1.3.6.1.4.1.12356.101.4.1.6.0"

  [[inputs.snmp.field]]
    name = "disk_capacity_mb"
    oid = "1.3.6.1.4.1.12356.101.4.1.7.0"

  [[inputs.snmp.field]]
    name = "sessions"
    oid = "1.3.6.1.4.1.12356.101.4.1.8.0"

  [[inputs.snmp.field]]
    name = "lowmem_percent"
    oid = "1.3.6.1.4.1.12356.101.4.1.9.0"

  [[inputs.snmp.field]]
    name = "session_rate_1m"
    oid = "1.3.6.1.4.1.12356.101.4.1.11.0"

  [[inputs.snmp.field]]
    name = "session_rate_10m"
    oid = "1.3.6.1.4.1.12356.101.4.1.12.0"

  [[inputs.snmp.field]]
    name = "session_rate_30m"
    oid = "1.3.6.1.4.1.12356.101.4.1.13.0"

  [[inputs.snmp.field]]
    name = "session_rate_60m"
    oid = "1.3.6.1.4.1.12356.101.4.1.14.0"
{% endfor %}
{% endif %}
