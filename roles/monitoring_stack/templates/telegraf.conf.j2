[agent]
  interval = "30s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  collection_jitter = "0s"
  flush_interval = "30s"
  flush_jitter = "5s"
  precision = ""
  hostname = "{{ inventory_hostname }}"
  omit_hostname = false

[[outputs.influxdb_v2]]
  urls = ["http://influxdb:8086"]
  token = "$INFLUX_TOKEN"
  organization = "{{ telegraf_influxdb_org }}"
  bucket = "{{ telegraf_influxdb_bucket }}"

[[inputs.docker]]
  endpoint = "unix:///var/run/docker.sock"
  gather_services = false

[[inputs.ping]]
  urls = {{ telegraf_ping_targets | to_json }}
  count = 3
  method = "native"

[[inputs.x509_cert]]
  sources = {{ telegraf_x509_targets | to_json }}
  timeout = "5s"
  insecure_skip_verify = true

{% if monitoring_proxmox_enabled | bool %}
{% for target in monitoring_proxmox_targets %}
[[inputs.proxmox]]
  base_url = "{{ target.base_url }}"
  api_token = "$PROXMOX_API_TOKEN"
  node_name = "{{ target.name }}"
  insecure_skip_verify = true
  response_timeout = "10s"
{% endfor %}
{% endif %}

{% if monitoring_snmp_enabled | bool %}
{% for target in monitoring_snmp_targets %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "snmp_device"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"

  [[inputs.snmp.field]]
    name = "sys_name"
    oid = "1.3.6.1.2.1.1.5.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "sys_uptime"
    oid = "1.3.6.1.2.1.1.3.0"

{% if target.device_type == "hp-ilo" %}
  [[inputs.snmp.field]]
    name = "thermal_condition"
    oid = "1.3.6.1.4.1.232.6.2.6.4.0"

  [[inputs.snmp.field]]
    name = "power_condition"
    oid = "1.3.6.1.4.1.232.6.2.9.1.0"

  [[inputs.snmp.field]]
    name = "power_redundancy_status"
    oid = "1.3.6.1.4.1.232.6.2.9.2.0"

  [[inputs.snmp.field]]
    name = "power_meter_current_watts"
    oid = "1.3.6.1.4.1.232.6.2.15.3.0"

  [[inputs.snmp.field]]
    name = "power_meter_previous_watts"
    oid = "1.3.6.1.4.1.232.6.2.15.4.0"

  [[inputs.snmp.field]]
    name = "storage_battery_condition"
    oid = "1.3.6.1.4.1.232.6.2.17.1.0"

{% endif %}
{% endfor %}
{% endif %}

{% if monitoring_snmp_enabled | bool %}
{% for target in monitoring_snmp_targets %}
{% if target.device_type == "hp-ilo" %}
{% for sensor in monitoring_ilo_temperature_sensors %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "hp_ilo_temperature"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"
    sensor_index = "{{ sensor.index }}"
    location = "{{ sensor.location | default('location-' ~ sensor.index) }}"

  [[inputs.snmp.field]]
    name = "celsius"
    oid = "1.3.6.1.4.1.232.6.2.6.8.1.4.0.{{ sensor.index }}"

  [[inputs.snmp.field]]
    name = "threshold_celsius"
    oid = "1.3.6.1.4.1.232.6.2.6.8.1.5.0.{{ sensor.index }}"

  [[inputs.snmp.field]]
    name = "condition"
    oid = "1.3.6.1.4.1.232.6.2.6.8.1.6.0.{{ sensor.index }}"
{% endfor %}

{% for fan in monitoring_ilo_fans %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "hp_ilo_fan"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"
    fan_index = "{{ fan.index }}"
    locale = "{{ fan.locale | default('fan-' ~ fan.index) }}"

  [[inputs.snmp.field]]
    name = "present"
    oid = "1.3.6.1.4.1.232.6.2.6.7.1.9.0.{{ fan.index }}"

  [[inputs.snmp.field]]
    name = "condition"
    oid = "1.3.6.1.4.1.232.6.2.6.7.1.10.0.{{ fan.index }}"
{% endfor %}

