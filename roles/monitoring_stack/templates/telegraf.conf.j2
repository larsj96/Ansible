  [[inputs.snmp.field]]
    name = "condition"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.3.0.{{ psu.index }}"

  [[inputs.snmp.field]]
    name = "status"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.4.0.{{ psu.index }}"

  [[inputs.snmp.field]]
    name = "input_status"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.5.0.{{ psu.index }}"

  [[inputs.snmp.field]]
    name = "used_watts"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.7.0.{{ psu.index }}"

  [[inputs.snmp.field]]
