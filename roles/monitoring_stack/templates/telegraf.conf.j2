  [[inputs.snmp.field]]
    name = "storage_battery_condition"
    oid = "1.3.6.1.4.1.232.6.2.17.1.0"

  [[inputs.snmp.field]]
    name = "rom_version"
    oid = "1.3.6.1.4.1.232.11.2.14.1.1.5.1"
