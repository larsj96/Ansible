[agent]
  interval = "30s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  collection_jitter = "0s"
  flush_interval = "30s"
  flush_jitter = "5s"
  precision = ""
  hostname = "{{ inventory_hostname }}"
  omit_hostname = false

[[outputs.influxdb_v2]]
  urls = ["http://influxdb:8086"]
  token = "$INFLUX_TOKEN"
  organization = "{{ telegraf_influxdb_org }}"
  bucket = "{{ telegraf_influxdb_bucket }}"

[[inputs.docker]]
  endpoint = "unix:///var/run/docker.sock"
  gather_services = false

[[inputs.ping]]
  urls = {{ telegraf_ping_targets | to_json }}
  count = 3
  method = "native"

[[inputs.x509_cert]]
  sources = {{ telegraf_x509_targets | to_json }}
  timeout = "5s"
  insecure_skip_verify = true

{% if monitoring_cloudflare_enabled %}
[[inputs.prometheus]]
  urls = ["http://cloudflare-exporter:{{ monitoring_cloudflare_container_port }}/metrics"]
  metric_version = 1
  fielddrop = ["_measurement_error", "_start", "_end"]
  namepass = ["cloudflare_*"]
  response_timeout = "{{ monitoring_cloudflare_telegraf_response_timeout | default('60s') }}"
{% endif %}

{% if monitoring_proxmox_enabled | bool %}
{% for target in monitoring_proxmox_targets %}
[[inputs.proxmox]]
  base_url = "{{ target.base_url }}"
  api_token = "$PROXMOX_API_TOKEN"
  node_name = "{{ target.name }}"
  insecure_skip_verify = true
  response_timeout = "10s"
{% endfor %}
{% endif %}

{% if monitoring_snmp_enabled | bool %}
{% for target in monitoring_snmp_targets %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "snmp_device"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"

  [[inputs.snmp.field]]
    name = "sys_name"
    oid = "1.3.6.1.2.1.1.5.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "sys_uptime"
    oid = "1.3.6.1.2.1.1.3.0"

{% if target.device_type == "hp-ilo" %}
  [[inputs.snmp.field]]
    name = "thermal_condition"
    oid = "1.3.6.1.4.1.232.6.2.6.4.0"

  [[inputs.snmp.field]]
    name = "power_condition"
    oid = "1.3.6.1.4.1.232.6.2.9.1.0"

  [[inputs.snmp.field]]
    name = "power_redundancy_status"
    oid = "1.3.6.1.4.1.232.6.2.9.2.0"

  [[inputs.snmp.field]]
    name = "power_meter_current_watts"
