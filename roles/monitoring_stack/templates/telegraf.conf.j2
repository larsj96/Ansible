  [[inputs.snmp.field]]
    name = "serial"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.11.0.{{ psu.index }}"
    is_tag = true

  [[inputs.snmp.field]]
    name = "spare_part"
    oid = "1.3.6.1.4.1.232.6.2.9.3.1.16.0.{{ psu.index }}"
