    oid = "1.3.6.1.4.1.232.6.2.9.3.1.8.0.{{ psu.index }}"
{% endfor %}

{% for battery in monitoring_ilo_storage_batteries %}
[[inputs.snmp]]
  agents = ["udp://{{ target.address }}:161"]
  version = 2
  community = "{{ monitoring_snmp_community }}"
  timeout = "5s"
  retries = 2
  name = "hp_ilo_storage_battery"

  [inputs.snmp.tags]
    device = "{{ target.name }}"
    device_type = "{{ target.device_type }}"
    battery_index = "{{ battery.index }}"

  [[inputs.snmp.field]]
    name = "model"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.7.0.{{ battery.index }}"
    is_tag = true

  [[inputs.snmp.field]]
    name = "part_number"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.8.0.{{ battery.index }}"
    is_tag = true

  [[inputs.snmp.field]]
    name = "serial"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.9.0.{{ battery.index }}"
    is_tag = true

  [[inputs.snmp.field]]
    name = "spare_part"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.11.0.{{ battery.index }}"
    is_tag = true

  [[inputs.snmp.field]]
    name = "condition"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.3.0.{{ battery.index }}"

  [[inputs.snmp.field]]
    name = "status"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.4.0.{{ battery.index }}"

  [[inputs.snmp.field]]
    name = "charge_percent"
    oid = "1.3.6.1.4.1.232.6.2.17.2.1.6.0.{{ battery.index }}"
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

