{
  "uid": "homelab-overview",
  "title": "Homelab Overview",
  "tags": ["homelab", "os", "influxdb", "telegraf"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"host\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      },
      {
        "name": "disk",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"path\", predicate: (r) => r._measurement == \"disk\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      },
      {
        "name": "iface",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"interface\", predicate: (r) => r._measurement == \"net\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"cpu\" and r.cpu == \"cpu-total\" and r._field == \"usage_idle\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _value: 100.0 - r._value, _field: r.host }))" }]
    },
    {
      "id": 2,
      "title": "Memory used",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"mem\" and r._field == \"used_percent\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)" }]
    },
    {
      "id": 3,
      "title": "System load 1m",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"load1\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)" }]
    },
    {
      "id": 4,
      "title": "Host uptime",
      "type": "stat",
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "d", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"uptime\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> last() |> map(fn: (r) => ({ r with _value: float(v: r._value) / 86400.0, _field: r.host }))" }]
    },
    {
      "id": 5,
      "title": "Root disk used",
      "type": "stat",
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"disk\" and r._field == \"used_percent\" and r.path == \"/\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> last()" }]
    },
    {
      "id": 6,
      "title": "Disk free",
      "type": "stat",
      "gridPos": { "x": 12, "y": 7, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"disk\" and r._field == \"free\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> filter(fn: (r) => \"${disk}\" == \"All\" or r.path == \"${disk}\") |> last()" }]
    },
    {
      "id": 7,
      "title": "Docker containers running",
      "type": "stat",
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"docker\" and r._field == \"n_containers_running\") |> last()" }]
    },
    {
      "id": 8,
      "title": "Disk usage by mount",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"disk\" and r._field == \"used_percent\") |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> filter(fn: (r) => \"${disk}\" == \"All\" or r.path == \"${disk}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.host + \" \" + r.path }))" }]
    },
    {
      "id": 9,
      "title": "Disk I/O throughput",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"diskio\" and (r._field == \"read_bytes\" or r._field == \"write_bytes\")) |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> derivative(unit: 1s, nonNegative: true) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.host + \" \" + r.name + \" \" + r._field }))" }]
    },
    {
      "id": 10,
      "title": "Network throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "Bps", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"net\" and (r._field == \"bytes_recv\" or r._field == \"bytes_sent\")) |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> filter(fn: (r) => \"${iface}\" == \"All\" or r.interface == \"${iface}\") |> derivative(unit: 1s, nonNegative: true) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.host + \" \" + r.interface + \" \" + r._field }))" }]
    },
    {
      "id": 11,
      "title": "Network errors and drops",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"net\" and (r._field == \"err_in\" or r._field == \"err_out\" or r._field == \"drop_in\" or r._field == \"drop_out\")) |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> filter(fn: (r) => \"${iface}\" == \"All\" or r.interface == \"${iface}\") |> derivative(unit: 1s, nonNegative: true) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.host + \" \" + r.interface + \" \" + r._field }))" }]
    },
    {
      "id": 12,
      "title": "Host inventory table",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => (r._measurement == \"system\" and (r._field == \"uptime\" or r._field == \"load1\")) or (r._measurement == \"mem\" and r._field == \"used_percent\") or (r._measurement == \"disk\" and r._field == \"used_percent\" and r.path == \"/\")) |> filter(fn: (r) => \"${host}\" == \"All\" or r.host == \"${host}\") |> last() |> keep(columns: [\"_time\", \"host\", \"_measurement\", \"_field\", \"_value\"] )" }]
    },
    {
      "id": 13,
      "title": "Docker container CPU",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"docker_container_cpu\" and r._field == \"usage_percent\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)" }]
    },
    {
      "id": 14,
      "title": "Docker container memory",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "influxdb", "uid": "influxdb-homelab" }, "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"docker_container_mem\" and r._field == \"usage_percent\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)" }]
    }
  ]
}
