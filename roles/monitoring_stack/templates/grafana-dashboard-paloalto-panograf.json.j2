{
  "uid": "paloalto-panograf-homelab",
  "title": "Palo Alto PAN-OS Panograf",
  "tags": ["homelab", "palo-alto", "panos", "panograf", "snmp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "hostname",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"hostname\", predicate: (r) => r._measurement == \"pan_system\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      },
      {
        "name": "zone",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"zone\", predicate: (r) => r._measurement == \"pan_zone\")",
        "refresh": 1,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "All" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU load",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and (r._field == \"hrProcessorLoad.1\" or r._field == \"hrProcessorLoad.2\" or r._field == \"hrProcessorLoad.3\" or r._field == \"hrProcessorLoad.4\")) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.hostname + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active sessions",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => (r._measurement == \"pan_vsys\" and r._field == \"panVsysActiveSessions\") or (r._measurement == \"pan_system\" and (r._field == \"panSessionActiveTcp\" or r._field == \"panSessionActiveUdp\" or r._field == \"panSessionActiveICMP\"))) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: if exists r.Vsys then r.Vsys + \" sessions\" else r._field }))"
        }
      ]
    },
    {
      "id": 3,
      "title": "GlobalProtect tunnels",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field == \"panGPGWUtilizationActiveTunnels\") |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "HA state",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field == \"panSysHAState\") |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> last()"
        }
      ]
    },
    {
      "id": 5,
      "title": "Zone CPS",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_zone\" and (r._field == \"panZoneActiveTcpCps\" or r._field == \"panZoneActiveUdpCps\" or r._field == \"panZoneActiveOtherIpCps\")) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> filter(fn: (r) => \"${zone}\" == \"All\" or r.zone == \"${zone}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.zone + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Vsys CPS",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_vsys\" and (r._field == \"panVsysActiveTcpCps\" or r._field == \"panVsysActiveUdpCps\" or r._field == \"panVsysActiveOtherIpCps\")) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.Vsys + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 7,
      "title": "Fans",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "rpm", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field =~ /^fan/) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.hostname + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 8,
      "title": "Temperature sensors",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field =~ /_temp/) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.hostname + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 9,
      "title": "Storage and packet buffers",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "used = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_buffers\" and r._field == \"hrStorageUsed\")\nsize = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_buffers\" and r._field == \"hrStorageSize\")\njoin(tables: {used: used, size: size}, on: [\"_time\", \"hostname\", \"hrStorageDescr\"]) |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> map(fn: (r) => ({ r with _value: float(v: r._value_used) / float(v: r._value_size) * 100.0, _field: r.hrStorageDescr })) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 10,
      "title": "Global counters per interval",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "pps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_global_counters\" or r._measurement == \"pan_drop\") |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> difference(nonNegative: true) |> map(fn: (r) => ({ r with _field: r._measurement + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 11,
      "title": "DoS and policy counters per interval",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
      "fieldConfig": { "defaults": { "unit": "pps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-homelab" },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_dos\") |> filter(fn: (r) => \"${hostname}\" == \"All\" or r.hostname == \"${hostname}\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> difference(nonNegative: true) |> map(fn: (r) => ({ r with _field: r._field }))"
        }
      ]
    }
  ]
}
