{
  "uid": "paloalto-panograf-homelab",
  "title": "Palo Alto PAN-OS Panograf",
  "tags": [
    "homelab",
    "palo-alto",
    "panos",
    "panograf",
    "snmp"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "hostname",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-homelab"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"hostname\", predicate: (r) => r._measurement == \"pan_system\")",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "zone",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-homelab"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"zone\", predicate: (r) => r._measurement == \"pan_zone\")",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "interface",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-homelab"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"homelab\", tag: \"ifName\", predicate: (r) => r._measurement == \"pan_interfaces\")",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU load",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and (r._field == \"hrProcessorLoad.1\" or r._field == \"hrProcessorLoad.2\" or r._field == \"hrProcessorLoad.3\" or r._field == \"hrProcessorLoad.4\")) |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.hostname + \" \" + r._field }))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active sessions",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => (r._measurement == \"pan_vsys\" and r._field == \"panVsysActiveSessions\") or (r._measurement == \"pan_system\" and (r._field == \"panSessionActiveTcp\" or r._field == \"panSessionActiveUdp\" or r._field == \"panSessionActiveICMP\"))) |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: if exists r.Vsys then r.Vsys + \" sessions\" else r._field }))"
        }
      ]
    },
    {
      "id": 3,
      "title": "GlobalProtect tunnels",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field == \"panGPGWUtilizationActiveTunnels\") |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "HA state",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
