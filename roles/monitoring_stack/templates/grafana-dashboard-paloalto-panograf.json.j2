        }
      ]
    },
    {
      "id": 7,
      "title": "Hardware Sensors",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
