            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_sensors\" and r._field == \"entPhySensorValue\") |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.entPhysicalName + \" (\" + r.entPhySensorUnitsDisplay + \")\" }))"
        }
      ],
      "description": "ENTITY-SENSOR values exposed by PAN-OS. PA-510 currently exposes CPU die temperature; it does not expose fan tachometer values over SNMP."
    },
    {
      "id": 8,
      "title": "Legacy Temperature OIDs",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_system\" and r._field =~ /_temp/) |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ r with _field: r.hostname + \" \" + r._field }))"
        }
      ],
      "description": "Legacy direct sensor OIDs retained for devices that expose them. Prefer Hardware Sensors when available."
    },
    {
      "id": 9,
      "title": "Storage and packet buffers",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-homelab"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-homelab"
          },
          "query": "used = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_buffers\" and r._field == \"hrStorageUsed\")\nsize = from(bucket: \"homelab\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"pan_buffers\" and r._field == \"hrStorageSize\")\njoin(tables: {used: used, size: size}, on: [\"_time\", \"hostname\", \"hrStorageDescr\"]) |> filter(fn: (r) => r.hostname =~ /^${hostname:regex}$/) |> map(fn: (r) => ({ r with _value: float(v: r._value_used) / float(v: r._value_size) * 100.0, _field: r.hrStorageDescr })) |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
