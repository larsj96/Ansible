---
# Copy to an ignored Ansible Vault file before deploying monitoring.
# Example:
#   cp group_vars/monitoring_secrets.yml.example group_vars/monitoring_secrets.yml
#   ansible-vault encrypt group_vars/monitoring_secrets.yml

influxdb_admin_password: "replace-with-long-random-password"
influxdb_admin_token: "replace-with-long-random-token-at-least-32-chars"
opensearch_initial_admin_password: "replace-with-long-random-password"
grafana_admin_password: "replace-with-long-random-password"
